{
  "name": "idle-neon-miner",
  "version": "0.1.0",
  "description": "Idle Neon Miner - neon idle game with asteroid mining",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite --host",
    "dev:clean": "bun run clear-cache && bun run dev",
    "build": "tsc --noEmit && bunx --bun vite build",
    "preview": "bunx --bun vite preview --host",
    "clear-cache": "node scripts/clear-cache.js",
    "fonts:download": "bun run scripts/download-fonts.ts",
    "fonts:manual": "bun run scripts/download-fonts.ts --manual",
    "fonts:fallback": "bun run scripts/download-fonts.ts --fallback",
    "cap:add": "bunx cap add",
    "cap:sync": "bunx cap sync",
    "cap:run": "bunx cap run",
    "check": "svelte-check --fail-on-warnings --diagnostic-sources js,svelte",
    "balance:import": "cd tools/balance-importer && bun install && bun run import",
    "balance:dev": "cd tools/balance-importer && bun run dev"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.0",
    "@capacitor/app": "^7.1.2",
    "@capacitor/core": "^7.6.0",
    "@capacitor/haptics": "^7.0.4",
    "@capacitor/local-notifications": "^7",
    "@capacitor/preferences": "^7.0.4",
    "@capacitor/status-bar": "^7.0.5",
    "gsap": "^3.14.2",
    "howler": "^2.2.4",
    "lucide-svelte": "^0.577.0",
    "motion": "^12.38.0",
    "nanostores": "^1.2.0",
    "pixi.js": "^8.17.1",
    "svelte": "^5.54.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/howler": "^2.2.12",
    "@types/node": "^20.19.37",
    "qrcode-terminal": "^0.12.0",
    "spectorjs": "^0.9.30",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
